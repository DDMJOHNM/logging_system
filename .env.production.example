# Copy to .env.production on the EC2 host (repo root: /opt/logging_system/.env.production).
# Never commit .env.production.

APP_NAME="Logging System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://YOUR_EC2_PUBLIC_DNS:8080

LOG_CHANNEL=stderr
LOG_LEVEL=info

DB_DATABASE=logging
DB_USERNAME=logging
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# On EC2 with docker-compose.prod.yml, DB_HOST is overridden to mysql in compose.
# For RDS later, set DB_HOST to the RDS endpoint in compose environment or here.

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
FILESYSTEM_DISK=local

# EC2 instance profile supplies credentials when these are empty.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

OBSERVABILITY_SQS_CONSUMER_ENABLED=true
OBSERVABILITY_SQS_QUEUE_URL=
